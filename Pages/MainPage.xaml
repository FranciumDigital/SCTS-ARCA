<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SCTS___Android_Remote_Control_Application.MainPage"
             BackgroundColor="{StaticResource Gray50}"
             Shell.NavBarIsVisible="False"
             Title="Accueil">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="30">

            <!-- HEADER -->
            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Image Source="applogowhitebg.png"
                       HeightRequest="64"
                       Aspect="AspectFit"/>
                <Label Text="SCTS – ARCA"
                       FontSize="28"
                       FontAttributes="Bold"
                       VerticalOptions="Center"
                       TextColor="{StaticResource White}"/>
            </HorizontalStackLayout>

            <!-- RUNS CARD -->
            <Border BackgroundColor="{StaticResource White}"
                    StrokeThickness="1"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryDark}" Opacity="0.25" Radius="15" Offset="0,5" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="0" HorizontalOptions="Center">
                    <Label Text="RUNS"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryDark}"
                           HorizontalOptions="Center"/>

                    <Image Source="chrono.png"
                           HeightRequest="256"
                           Aspect="AspectFit"/>

                    <Button Text="Démarrer un run"
                            BackgroundColor="{StaticResource Tertiary}"
                            TextColor="{StaticResource White}"
                            CornerRadius="14"
                            FontSize="22"
                            HeightRequest="56"
                            HorizontalOptions="Fill"
                            Clicked="StartRunButtonClicked"/>
                </VerticalStackLayout>
            </Border>

            <!-- MODULES CARD -->
            <Border BackgroundColor="{StaticResource White}"
                    StrokeThickness="0"
                    Padding="20">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="18" />
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryDark}" Opacity="0.25" Radius="15" Offset="0,5" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="20">
                    <Label Text="MODULES"
                           FontSize="22"
                           FontAttributes="Bold"
                           TextColor="{StaticResource PrimaryDark}"
                           HorizontalOptions="Center"/>

                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center" HorizontalOptions="Fill">
                        <Label Text="Control HUB" FontSize="18" TextColor="{StaticResource PrimaryDark}" HorizontalOptions="Start"/>
                        <Image Source="greencheckcircle.png" HeightRequest="32" Aspect="AspectFit" HorizontalOptions="End"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Displays" FontSize="18" TextColor="{StaticResource PrimaryDark}" HorizontalOptions="Start"/>
                        <Image Source="greencheckcircle.png" HeightRequest="32" Aspect="AspectFit" HorizontalOptions="End"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Indicators" FontSize="18" TextColor="{StaticResource PrimaryDark}" HorizontalOptions="Start"/>
                        <Image Source="greencheckcircle.png" HeightRequest="32" Aspect="AspectFit" HorizontalOptions="End"/>
                    </HorizontalStackLayout>

                    <HorizontalStackLayout Spacing="15" VerticalOptions="Center">
                        <Label Text="Pads" FontSize="18" TextColor="{StaticResource PrimaryDark}" HorizontalOptions="Start"/>
                        <Image Source="greencheckcircle.png" HeightRequest="32" Aspect="AspectFit" HorizontalOptions="End"/>
                    </HorizontalStackLayout>
                </VerticalStackLayout>
            </Border>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
