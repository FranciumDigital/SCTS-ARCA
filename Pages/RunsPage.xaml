<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SCTS___Android_Remote_Control_Application.RunsPage"
             Title="Runs">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <Label Text="CHRONOMÈTRE" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>

            <Label x:Name="TimerLabel" Text="00:00.000" FontSize="48" HorizontalOptions="Center" TextColor="Black"/>

            <HorizontalStackLayout Spacing="12" HorizontalOptions="Center">
                <Button x:Name="StartStopButton" Text="Démarrer" WidthRequest="140" Clicked="StartStopButtonClicked"/>
                <Button x:Name="ResetButton" Text="Réinitialiser" WidthRequest="140" Clicked="ResetButtonClicked"/>
            </HorizontalStackLayout>

            <Button Text="Enregistrer le temps" BackgroundColor="{StaticResource Tertiary}" TextColor="{StaticResource White}" CornerRadius="12" Clicked="SaveTimeButtonClicked"/>

            <Label Text="Historique des temps" FontSize="18" FontAttributes="Bold"/>
            <CollectionView x:Name="HistoryCollection" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{StaticResource Gray50}" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="12" Margin="0,6">
                            <Label Text="{Binding}"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
