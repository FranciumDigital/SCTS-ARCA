<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SCTS___Android_Remote_Control_Application.CreateAccountPage"
             NavigationPage.HasNavigationBar="False"
             Title="Créer un compte">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">

            <!-- Bouton retour personnalisé -->
            <Button Text="← Retour"
                    BackgroundColor="Transparent"
                    TextColor="{StaticResource White}"
                    FontSize="18"
                    HorizontalOptions="Start"
                    Clicked="OnBackButtonClicked"
                    Margin="0,10,0,0"/>

            <Border BackgroundColor="{StaticResource White}"
        StrokeThickness="1"
        Padding="25">

                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="22"/>
                </Border.StrokeShape>

                <Border.Shadow>
                    <Shadow Brush="{StaticResource PrimaryDark}"
                Opacity="0.25"
                Radius="15"
                Offset="0,6" />
                </Border.Shadow>

                <VerticalStackLayout Spacing="10">
                    <!-- Étape licence -->
                    <VerticalStackLayout x:Name="StepLicense" Spacing="10">
                        <Label Text="Entrez votre numéro de licence:" FontSize="18"/>
                        <Entry x:Name="LicenseEntry" Placeholder="Numéro de licence" Keyboard="Numeric"/>
                        <Button Text="Valider" Clicked="ValidateLicenseClicked"/>
                    </VerticalStackLayout>

                    <!-- Étape mot de passe -->
                    <VerticalStackLayout x:Name="StepPassword" Spacing="10" IsVisible="False">
                        <Label Text="Créez un mot de passe (6 lettres/chiffres):" FontSize="18"/>
                        <Entry x:Name="PasswordEntry" Placeholder="Mot de passe" IsPassword="True"/>
                        <Button Text="Valider" Clicked="ValidatePasswordClicked"/>
                    </VerticalStackLayout>

                    <!-- Étape email -->
                    <VerticalStackLayout x:Name="StepEmail" Spacing="10" IsVisible="False">
                        <Label Text="Entrez votre email:" FontSize="18"/>
                        <Entry x:Name="EmailEntry" Placeholder="Email"/>
                        <Button Text="Envoyer code" Clicked="SendVerificationCodeClicked"/>
                    </VerticalStackLayout>

                    <!-- Étape code de vérification -->
                    <VerticalStackLayout x:Name="StepCode" Spacing="10" IsVisible="False">
                        <Label Text="Entrez le code de vérification reçu:" FontSize="18"/>
                        <Entry x:Name="CodeEntry" Placeholder="Code" Keyboard="Numeric"/>
                        <Button Text="Valider code" Clicked="ValidateCodeClicked"/>
                    </VerticalStackLayout>
                </VerticalStackLayout>

            </Border>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>