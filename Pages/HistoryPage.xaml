<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="SCTS___Android_Remote_Control_Application.HistoryPage"
             Shell.NavBarIsVisible="False"
             Title="Historique">

    <ScrollView>
        <VerticalStackLayout Padding="24" Spacing="20">
            <Label Text="HISTORIQUE DES RUNS" FontSize="24" FontAttributes="Bold" HorizontalOptions="Center"/>

            <CollectionView x:Name="RunsHistoryCollection" SelectionMode="None">
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Border BackgroundColor="{StaticResource Gray50}" StrokeThickness="1" Stroke="{StaticResource Gray200}" Padding="12" Margin="0,6">
                            <Label Text="{Binding}"/>
                        </Border>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
