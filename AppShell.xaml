<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="SCTS___Android_Remote_Control_Application.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:SCTS___Android_Remote_Control_Application"
    Shell.TabBarBackgroundColor="{StaticResource PrimaryDark}"
    Shell.TabBarForegroundColor="{StaticResource White}"
    Shell.TabBarUnselectedColor="{StaticResource Gray300}"
    Shell.TabBarTitleColor="{StaticResource White}">



    <TabBar>

        <Tab Title="Accueil" Icon="icon_home.png">
            <ShellContent
                ContentTemplate="{DataTemplate local:MainPage}"
                Route="MainPage" />
        </Tab>

        <Tab Title="Historique" Icon="icon_runs.png">
            <ShellContent
                ContentTemplate="{DataTemplate local:HistoryPage}"
                Route="HistoryPage" />
        </Tab>

        <Tab Title="Paramètres" Icon="icon_settings.png">
            <ShellContent
                ContentTemplate="{DataTemplate local:SettingsPage}"
                Route="SettingsPage" />
        </Tab>

    </TabBar>

</Shell>